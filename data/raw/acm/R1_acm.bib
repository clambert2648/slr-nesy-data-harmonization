@inproceedings{10.1145/3736426.3736447,
author = {Xu, Liming},
title = {Transformation and Innovation in Computer Science Services Driven by Data Sharing},
year = {2025},
isbn = {9798400714238},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3736426.3736447},
doi = {10.1145/3736426.3736447},
abstract = {Global communication made by the new technology revolution transformed the interaction of knowledge among disciplines in a new way and thus created two new opportunities and challenges for knowledge computing service systems. Present bottlenecks mainly consist of the following issues: One is massive data increase, which takes advantage of the exponential growth of computing power and reduces the opportunities for scholar to access data and two is lagging or absent standard rules, which hinders scholarly data distribution and circulation between scholars.This study adopts an application-oriented framework consisting of case analysis, validation and solution extraction to address improvement opportunities for computational services of data sharing systems. Fragmented cross-disciplinary data communication standardization, ownership confusion, rigid management mode and lack of a flexible service design are observed to be the major operational obstacles of data sharing systems.The comparison of state-of-art implementation in teaching, learning, science, and technology reveals significant sharing paradigms and opportunities for innovation through discussing platform-based resolution possibilities leading to multidimensional optimization proposals in technical, service and regulation.},
booktitle = {Proceedings of the 2025 International Conference on Digital Management and Information Technology},
pages = {120–125},
numpages = {6},
keywords = {Case Study, Computer Science Services, Data Sharing, Digital Transformation},
location = {
},
series = {DMIT '25}
}

@inproceedings{10.1145/3318464.3389742,
author = {Cappuzzo, Riccardo and Papotti, Paolo and Thirumuruganathan, Saravanan},
title = {Creating Embeddings of Heterogeneous Relational Datasets for Data Integration Tasks},
year = {2020},
isbn = {9781450367356},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3318464.3389742},
doi = {10.1145/3318464.3389742},
abstract = {Deep learning based techniques have been recently used with promising results for data integration problems. Some methods directly use pre-trained embeddings that were trained on a large corpus such as Wikipedia. However, they may not always be an appropriate choice for enterprise datasets with custom vocabulary. Other methods adapt techniques from natural language processing to obtain embeddings for the enterprise's relational data. However, this approach blindly treats a tuple as a sentence, thus losing a large amount of contextual information present in the tuple. We propose algorithms for obtaining local embeddings that are effective for data integration tasks on relational databases. We make four major contributions. First, we describe a compact graph-based representation that allows the specification of a rich set of relationships inherent in the relational world. Second, we propose how to derive sentences from such a graph that effectively "describe" the similarity across elements (tokens, attributes, rows) in the two datasets. The embeddings are learned based on such sentences. Third, we propose effective optimization to improve the quality of the learned embeddings and the performance of integration tasks. Finally, we propose a diverse collection of criteria to evaluate relational embeddings and perform an extensive set of experiments validating them against multiple baseline methods. Our experiments show that our framework, EmbDI, produces meaningful results for data integration tasks such as schema matching and entity resolution both in supervised and unsupervised settings.},
booktitle = {Proceedings of the 2020 ACM SIGMOD International Conference on Management of Data},
pages = {1335–1349},
numpages = {15},
keywords = {data integration, deep learning, embeddings, entity resolution, schema matching},
location = {Portland, OR, USA},
series = {SIGMOD '20}
}

